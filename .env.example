# ============================================================
# Gamlepappa Smarthus - Hunstein 48c Smart Home Dashboard
# Kopier denne filen til ".env" og fyll inn verdiene dine.
# ============================================================

# --- Homey Pro tilgang -------------------------------------
# Personal Access Token fra https://my.homey.app/me  (klikk "Account" -> "API Keys")
HOMEY_PAT=

# (valgfritt) Cloud-ID til Homey Pro - finnes på samme side under "Homey ID".
# Hvis du lar denne stå tom vil backenden prøve å autodetektere via PAT.
HOMEY_CLOUD_ID=

# --- Lokasjon for værwidget --------------------------------
# Brukes mot met.no Locationforecast API. Standard er Hunstein 48c i Bergen.
HOME_LAT=60.3913
HOME_LON=5.3221
HOME_PLACE=Hunstein 48c

# --- Server -------------------------------------------------
PORT=8080
NODE_ENV=production

# --- Demo-modus --------------------------------------------
# Sett til "true" for å kjøre uten Homey-tilkobling (bruker mock-data).
# Praktisk under utvikling og ved første gangs deploy før PAT er klar.
DEMO_MODE=false

# --- Frontend (client) -------------------------------------
# I produksjon er dette tomt fordi backend serverer frontend på samme origin.
# I dev settes dette automatisk av Vite-proxyen.
VITE_API_BASE=
